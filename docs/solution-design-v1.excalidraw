      "autoResize": true,
      "text": "Critical logic",
      "originalText": "Critical logic"
    },
    {
      "id": "r0DIbHwCrgO8TPh0k0gzL",
      "type": "text",
      "x": 1236.2306597428008,
      "y": 264.22736928472546,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 851838974,
      "version": 95,
      "versionNonce": 842319202,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774696357167,
      "link": null,
      "locked": false,
      "index": "b0P",
      "width": 469.8396911621094,
      "height": 125,
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 11,
      "autoResize": true,
      "text": "• normalized_key removes quantity and unit noise\n• DISTINCT recipe_id + normalized_key avoids double counts\n• Task 1 is precomputed in SQL for fast reads\n• Task 2 uses TF-IDF on title + raw ingredients\n• Errors return clear API responses",
      "originalText": "• normalized_key removes quantity and unit noise\n• DISTINCT recipe_id + normalized_key avoids double counts\n• Task 1 is precomputed in SQL for fast reads\n• Task 2 uses TF-IDF on title + raw ingredients\n• Errors return clear API responses"
    },
    {
      "id": "vQaf7uu4A2X8l8EcBDfJn",
      "type": "text",
      "x": 1177.0693288098485,
      "y": 465.09658377140977,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
