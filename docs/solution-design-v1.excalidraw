        "x1EEndcy8HtFDrFNFLOxt"
      ],
      "frameId": null,
      "roundness": null,
      "seed": 35,
      "version": 435,
      "versionNonce": 1668687842,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774696869716,
      "link": null,
      "locked": false,
      "index": "aX",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 17,
      "autoResize": false,
      "text": "Task 1 solution\n- Build normalized_key from ingredient text\n- Deduplicate by recipe_id + normalized_key\n- Aggregate cooccurrence in SQL\n\nTask 2 solution\n- TF-IDF over title + raw ingredients\n- Return top 5 with similarity score\n\nTradeoffs\n- Simpler than full NLP pipelines\n- Strong enough for PoC, not search-engine scale",
      "originalText": "Task 1 solution\n- Build normalized_key from ingredient text\n- Deduplicate by recipe_id + normalized_key\n- Aggregate cooccurrence in SQL\n\nTask 2 solution\n- TF-IDF over title + raw ingredients\n- Return top 5 with similarity score\n\nTradeoffs\n- Simpler than full NLP pipelines\n- Strong enough for PoC, not search-engine scale"
    },
