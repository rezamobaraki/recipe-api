      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 17,
      "autoResize": true,
      "text": "CLI\n- python -m src.cli ingest\n\nHTTP\n- GET /api/ingredient-cooccurrence\n- POST /api/recipe-duplicates\n- GET /health\n\nFactory app\n- uvicorn src.main:create_app --factory",
      "originalText": "CLI\n- python -m src.cli ingest\n\nHTTP\n- GET /api/ingredient-cooccurrence\n- POST /api/recipe-duplicates\n- GET /health\n\nFactory app\n- uvicorn src.main:create_app --factory"
    },
