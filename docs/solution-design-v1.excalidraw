      "index": "aT",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 17,
      "autoResize": false,
      "text": "Flow\n- Read recipe JSON\n- Normalize each ingredient string\n- Bulk insert recipes and ingredients\n- Build ingredient_cooccurrence in SQL\n- Serve Task 1 from precomputed table\n- Score Task 2 from stored recipe text",
      "originalText": "Flow\n- Read recipe JSON\n- Normalize each ingredient string\n- Bulk insert recipes and ingredients\n- Build ingredient_cooccurrence in SQL\n- Serve Task 1 from precomputed table\n- Score Task 2 from stored recipe text"
    },
