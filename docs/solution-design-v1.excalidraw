      "lineHeight": 1.25,
      "baseline": 14,
      "autoResize": true,
      "text": "Critical logic",
      "originalText": "Critical logic"
    },
    {
      "id": "roxGy2IOrqfzW2sEUZ4MW",
      "type": "text",
      "x": 2603.675528955544,
      "y": -846.4387270042971,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 768743294,
      "version": 95,
      "versionNonce": 1474230498,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774696547681,
      "link": null,
      "locked": false,
      "index": "b1q",
      "width": 469.8396911621094,
      "height": 125,
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 11,
      "autoResize": true,
      "text": "• normalized_key removes quantity and unit noise\n• DISTINCT recipe_id + normalized_key avoids double counts\n• Task 1 is precomputed in SQL for fast reads\n• Task 2 uses TF-IDF on title + raw ingredients\n• Errors return clear API responses",
      "originalText": "• normalized_key removes quantity and unit noise\n• DISTINCT recipe_id + normalized_key avoids double counts\n• Task 1 is precomputed in SQL for fast reads\n• Task 2 uses TF-IDF on title + raw ingredients\n• Errors return clear API responses"
    },
    {
      "id": "s-aIq4C8UWBTJTWHsMVmD",
      "type": "text",
      "x": 2544.5141980225917,
