      "height": 35,
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 14,
      "autoResize": true,
      "text": "Functional requirements",
      "originalText": "Functional requirements"
    },
    {
      "id": "rclean0008",
      "type": "text",
      "x": 1524.4461067168743,
      "y": -445.4465101251447,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1491589429,
      "version": 306,
      "versionNonce": 234074064,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773536182105,
      "link": null,
      "locked": false,
      "index": "zz0008",
      "width": 403.2197570800781,
      "height": 125,
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 11,
      "autoResize": true,
      "text": "• Load CSV + JSONL into reusable models\n• Deduplicate to one row per flight_id\n• Join equipment → aircraft specs\n• Expose route/day capacity API\n• Handle dirty or missing data safely",
      "originalText": "• Load CSV + JSONL into reusable models\n• Deduplicate to one row per flight_id\n• Join equipment → aircraft specs\n• Expose route/day capacity API\n• Handle dirty or missing data safely"
    },
    {
      "id": "rclean0010",
      "type": "text",
      "x": 1461.1183710052658,
      "y": -263.838124732285,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
