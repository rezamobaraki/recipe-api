      "baseline": 14,
      "autoResize": true,
      "text": "Problem & data",
      "originalText": "Problem & data"
    },
    {
      "id": "rclean0005",
      "type": "text",
      "x": 1525.7776843248878,
      "y": -867.2458771666754,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1451729753,
      "version": 477,
      "versionNonce": 2115383600,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773536092276,
      "link": null,
      "locked": false,
      "index": "zz0005",
      "width": 477.899658203125,
      "height": 300,
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 11,
      "autoResize": true,
      "text": "Goal\n• Estimate available cargo capacity by route/day\n\nInputs\n• ADS-B flight event CSVs (7 files, ~700K rows)\n• Aircraft JSONL with payload + volume\n\nKey issues\n• ';' delimiter\n• 2–6 events per flight_id\n• Missing origin / flight fields\n• Many equipment codes unmatched",
      "originalText": "Goal\n• Estimate available cargo capacity by route/day\n\nInputs\n• ADS-B flight event CSVs (7 files, ~700K rows)\n• Aircraft JSONL with payload + volume\n\nKey issues\n• ';' delimiter\n• 2–6 events per flight_id\n• Missing origin / flight fields\n• Many equipment codes unmatched"
    },
    {
      "id": "rclean0007",
      "type": "text",
      "x": 1458.6220318635878,
      "y": -515.3665423286319,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 22978327,
      "version": 305,
      "versionNonce": 835797808,
      "isDeleted": false,
      "boundElements": [],
