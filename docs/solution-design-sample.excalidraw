      "autoResize": true,
      "text": "Non-functional decisions",
      "originalText": "Non-functional decisions"
    },
    {
      "id": "rclean0011",
      "type": "text",
      "x": 1529.762842210336,
      "y": -195.07255031623504,
      "angle": 0,
      "strokeColor": "#1e1e1e",
